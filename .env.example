# Required: Database connection (uses DATABASE_URL first, falls back to POSTGRES_URL)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
POSTGRES_URL=""

# Required: Supabase
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Required: Resend (email sending)
RESEND_API_KEY=""

# Optional: Site URL (canonical URL for OAuth redirects, auto-detected on Vercel)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: OAuth providers (configure in Supabase dashboard or supabase/config.toml)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""

# Optional: Seed script
ADMIN_EMAIL="admin@example.com"
